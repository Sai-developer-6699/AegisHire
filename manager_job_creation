    <script>
        // Mobile sidebar toggle
        const sidebarToggle = document.getElementById('sidebar-toggle');
        const closeSidebar = document.getElementById('close-sidebar');
        const mobileSidebar = document.getElementById('mobile-sidebar');
        
        sidebarToggle.addEventListener('click', () => {
            mobileSidebar.classList.toggle('hidden');
        });
        
        closeSidebar.addEventListener('click', () => {
            mobileSidebar.classList.add('hidden');
        });
        
        // Job category selection and skills display
        const jobCategory = document.getElementById('jobCategory');
        const technicalSkills = document.getElementById('technicalSkills');
        const softSkills = document.getElementById('softSkills');
        
        const skillsData = {
            frontend: {
                technical: ['HTML', 'CSS', 'JavaScript', 'React', 'Vue', 'Angular'],
                soft: ['Communication', 'Attention to Detail', 'Teamwork']
            },
            backend: {
                technical: ['Node.js', 'Python', 'Java', 'SQL', 'MongoDB', 'Express'],
                soft: ['Problem Solving', 'Time Management', 'Critical Thinking']
            },
            datascience: {
                technical: ['Python', 'R', 'SQL', 'Machine Learning', 'Data Visualization', 'Statistics'],
                soft: ['Analytical Thinking', 'Communication', 'Research']
            }
        };
        
        function createSkillPill(skill, type) {
            const pill = document.createElement('div');
            pill.className = 'skill-pill cursor-pointer px-4 py-2 rounded-full border border-[#2ed573] text-[#9ca3af] text-sm transition-all';
            pill.textContent = skill;
            pill.dataset.selected = 'false';
            
            pill.addEventListener('click', () => {
                if (pill.dataset.selected === 'false') {
                    pill.dataset.selected = 'true';
                    pill.classList.add('active');
                } else {
                    pill.dataset.selected = 'false';
                    pill.classList.remove('active');
                }
            });
            
            return pill;
        }
        
        jobCategory.addEventListener('change', () => {
            const category = jobCategory.value;
            
            if (skillsData[category]) {
                // Clear existing skills
                technicalSkills.innerHTML = '';
                softSkills.innerHTML = '';
                
                // Add technical skills
                skillsData[category].technical.forEach(skill => {
                    const pill = createSkillPill(skill, 'technical');
                    technicalSkills.appendChild(pill);
                    
                    // Auto-select first three skills for frontend
                    if (category === 'frontend' && ['HTML', 'CSS', 'JavaScript'].includes(skill)) {
                        pill.click();
                    }
                });
                
                // Add soft skills
                skillsData[category].soft.forEach(skill => {
                    const pill = createSkillPill(skill, 'soft');
                    softSkills.appendChild(pill);
                    
                    // Auto-select all soft skills for frontend
                    if (category === 'frontend') {
                        pill.click();
                    }
                });
            }
        });
        
        // Form submission
        const jobForm = document.getElementById('jobForm');
        
        jobForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            // Get selected skills
            const selectedTechnicalSkills = Array.from(document.querySelectorAll('#technicalSkills .skill-pill[data-selected="true"]'))
                .map(pill => pill.textContent);
            
            const selectedSoftSkills = Array.from(document.querySelectorAll('#softSkills .skill-pill[data-selected="true"]'))
                .map(pill => pill.textContent);
            
            // Create job data object
            const jobData = {
                title: document.getElementById('jobTitle').value,
                category: document.getElementById('jobCategory').value,
                experience: document.getElementById('experience').value,
                education: document.getElementById('education').value,
                location: document.getElementById('location').value,
                technicalSkills: selectedTechnicalSkills,
                softSkills: selectedSoftSkills,
                description: document.getElementById('jobDescription').value,
                otherRequirements: document.getElementById('otherRequirements').value
            };
            
            // In a real app, you would send this data to your backend
            console.log('Job data submitted:', jobData);
            
            // Show success message
            alert('Job post sent to HR for evaluation!');
        });
        
        // Reset form
        const resetButton = document.querySelector('button[type="reset"]');
        resetButton.addEventListener('click', () => {
            // Clear skills containers
            technicalSkills.innerHTML = '<p class="text-[#9ca3af] italic">Select a job category to see relevant skills</p>';
            softSkills.innerHTML = '<p class="text-[#9ca3af] italic">Select a job category to see relevant skills</p>';
        });
    </script>
